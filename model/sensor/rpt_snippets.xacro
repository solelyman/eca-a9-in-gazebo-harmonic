<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="no_collision">
    <collision>
      <geometry>
        <cylinder length="${0.000001}" radius="${0.000001}" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 ${0.5*pi} 0"/>
    </collision>
  </xacro:macro>

  <xacro:macro name="default_rpt" params="namespace parent_link *origin">
    <xacro:rpt_plugin_macro
      namespace="${namespace}"
      suffix=""
      parent_link="${parent_link}"
      noise_amplitude="0.0"
      noise_sigma="0.0"
      topic="rpt">
      <xacro:insert_block name="origin" />
    </xacro:rpt_plugin_macro>
  </xacro:macro>

  <xacro:macro name="rpt_plugin_macro"
    params="namespace suffix parent_link topic noise_sigma noise_amplitude
    *origin">
    <link name="${namespace}/rpt${suffix}_link">
      <inertial>
        <mass value="0.001" />  <!-- [kg] -->
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.000000017" ixy="0" ixz="0" iyy="0.000000017" iyz="0" izz="0.000000017" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="file://$(find uuv_sensor_ros_plugins)/mesh/rpt.dae" scale="1 1 1"/>
        </geometry>
      </visual>
      <xacro:no_collision/>
    </link>

    <joint name="${namespace}/rpt${suffix}_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent_link}" />
      <child link="${namespace}/rpt${suffix}_link" />
      <limit upper="0" lower="0" effort="0" velocity="0" />
      <axis xyz="1 0 0"/>
    </joint>

    <!-- <gazebo>
      <plugin filename="libuuv_gazebo_ros_rpt_plugin.so" name="libuuv_gazebo_rpt${suffix}_plugin">
        <robot_namespace>${namespace}</robot_namespace> 
        <link_name>${namespace}/rpt${suffix}_link</link_name> 
        <static_reference_frame>ssbl</static_reference_frame> 
        <sensor_topic>${topic}</sensor_topic> 
        <update_rate>0.5</update_rate> 
        <noise_sigma>${noise_sigma}</noise_sigma> 
        <noise_amplitude>${noise_amplitude}</noise_amplitude>
        <enable_gazebo_messages>false</enable_gazebo_messages>
      </plugin>
    </gazebo> -->
  </xacro:macro>
</robot>
